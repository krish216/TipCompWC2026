#!/usr/bin/env node
/**
 * seed.js — populates the fixtures table with all 104 WC2026 matches.
 * Run: node scripts/seed.js
 * Requires: NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in env
 */

