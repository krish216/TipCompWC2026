// ─── Knockout stage placeholders ─────────────────────────────────────────────
const KNOCKOUT = [
  // Round of 32
  { id: 101, round: 'r32', home: 'TBD 1A', away: 'TBD pool 1', kickoff_utc: '2026-07-01T19:00:00Z', venue: 'Estadio Azteca, Mexico City' },
  { id: 102, round: 'r32', home: 'TBD 1C', away: 'TBD 2D',     kickoff_utc: '2026-07-01T22:00:00Z', venue: 'MetLife Stadium, New York/NJ' },
  // ... (remaining 14 R32 + 8 R16 + 4 QF + 2 SF + TP + F)
  // Round of 16
  { id: 201, round: 'r16', home: 'W101', away: 'W102', kickoff_utc: '2026-07-06T19:00:00Z', venue: 'Gillette Stadium, Boston' },
  // Quarter-finals
  { id: 301, round: 'qf',  home: 'W201', away: 'W202', kickoff_utc: '2026-07-12T19:00:00Z', venue: 'AT&T Stadium, Dallas' },
  // Semi-finals
  { id: 401, round: 'sf',  home: 'W301', away: 'W302', kickoff_utc: '2026-07-15T19:00:00Z', venue: 'MetLife Stadium, New York/NJ' },
  { id: 402, round: 'sf',  home: 'W303', away: 'W304', kickoff_utc: '2026-07-16T19:00:00Z', venue: 'AT&T Stadium, Dallas' },
  // 3rd place
  { id: 501, round: 'tp',  home: 'Loser SF1', away: 'Loser SF2', kickoff_utc: '2026-07-18T19:00:00Z', venue: 'Hard Rock Stadium, Miami' },
  // Final
  { id: 601, round: 'f',   home: 'Winner SF1', away: 'Winner SF2', kickoff_utc: '2026-07-19T19:00:00Z', venue: 'MetLife Stadium, New York/NJ' },
]

async function seed() {
  console.log('🌱 Seeding fixtures...')
  const all = [...GROUP_STAGE, ...KNOCKOUT]

  const { error } = await supabase
    .from('fixtures')
    .upsert(all, { onConflict: 'id' })

  if (error) {
    console.error('❌ Seed failed:', error.message)
    process.exit(1)
  }

  console.log(`✅ Seeded ${all.length} fixtures`)
}

seed()
